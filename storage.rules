rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Meal photos. Path: /mealPhotos/{uid}/{mealId}.{ext}
    //
    // Lives in its own top-level namespace so we can apply a Cloud Storage
    // lifecycle rule that deletes any object under /mealPhotos/ after 24
    // hours — see lifecycle.json. The macros extracted from the photo are
    // persisted in Firestore; the photo itself is just an input and gets
    // garbage-collected.
    //
    // Read: any signed-in user. Photo download URLs aren't enumerable from
    // outside; they live inside Firestore meal docs which are gated on
    // group membership, so anyone who has the URL has already passed
    // Firestore's group-member check.
    //
    // Write: only the owning user, ≤10 MB, image/* content types.
    match /mealPhotos/{uid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
