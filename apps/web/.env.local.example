# Firebase web SDK config — copy this to .env.local and fill in.
# Find these values in Firebase Console > Project settings > General > Your apps > Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Server-only secrets — never prefix with NEXT_PUBLIC_ ===

# Anthropic API key — console.anthropic.com → API keys.
# Used by the /api/vision/* routes for Claude Opus 4.7 vision calls.
ANTHROPIC_API_KEY=

# Firebase Admin service account — used to verify Firebase ID tokens server-side
# on the /api/* routes. Generate JSON via Firebase Console → Project Settings →
# Service accounts → Generate new private key. Then split into the three vars
# below. The private key contains literal "\n" sequences when pasted into
# .env — leave them escaped; the server unescapes at load time.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
