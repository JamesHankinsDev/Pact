# Firebase web SDK config — same project as the web app, but with the
# EXPO_PUBLIC_ prefix so Expo embeds them at build time. Copy to .env and
# fill in from Firebase Console → Project Settings → Your apps → Web app.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth Web client ID for sign-in via expo-auth-session.
# Find under Firebase Console → Authentication → Sign-in method → Google →
# Web SDK configuration → Web client ID. Use the same value across all
# platforms; expo-auth-session/Google handles the redirect URI.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
