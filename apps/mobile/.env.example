# Firebase web SDK config — same project as the web app, but with the
# EXPO_PUBLIC_ prefix so Expo embeds them at build time. Copy to .env and
# fill in from Firebase Console → Project Settings → Your apps → Web app.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs — Google requires a SEPARATE OAuth client per
# platform (bundle ID / package name / web origin). Set whichever ones
# match how you'll run the app:
#
#  - Firebase Console → ⚙️ Project Settings → Your apps → Add app → iOS
#    (bundle ID: com.jameshankins.pact). After registering, Firebase
#    auto-creates the iOS OAuth client; find it at
#    Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 client IDs.
#  - Same for Android (package name: com.jameshankins.pact + SHA-1).
#  - The web client ID is the one Firebase makes when you enable Google
#    sign-in for the Web SDK; used by apps/web.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Base URL for the web app's API routes (e.g. /api/vision/meal). Use:
#   - http://localhost:3000           — iOS simulator on the same Mac
#   - http://10.0.2.2:3000            — Android emulator
#   - http://192.168.x.y:3000         — physical device on the same Wi-Fi
#   - https://<your>.vercel.app       — once deployed to Vercel
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
