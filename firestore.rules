rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember(groupId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // A user owns their own profile doc.
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Public-readable invite codes — used to look up groupId on the join flow.
    // Created server-side / by group creator only; not user-writable beyond that.
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Groups are private to their members. The creator must include themselves
    // in memberUids on creation. Updates by members; non-members can self-add
    // (only their own uid, only the memberUids field) — gated by knowing the
    // groupId, which is reachable only via /inviteCodes/{code}.
    match /groups/{groupId} {
      allow read: if isMember(groupId);
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() <= 6;
      allow update: if isMember(groupId)
        || (
          signedIn()
          && !isMember(groupId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'updatedAt'])
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.auth.uid in request.resource.data.memberUids
          && resource.data.memberUids.size() < 6
        );
      allow delete: if false;

      // Per-member display info (name/initials/color snapshot at join time).
      // All members of a group can read each other's slot; each member writes
      // only their own.
      match /members/{uid} {
        allow read: if isMember(groupId);
        allow create, update: if signedIn()
          && request.auth.uid == uid
          && isMember(groupId)
          && request.resource.data.uid == uid;
        allow delete: if false;
      }

      // Per-week pacts, workouts, meals, etc. inherit member-only access.
      match /pacts/{week} {
        allow read, write: if isMember(groupId);
      }
      match /workouts/{workoutId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId)
          && request.resource.data.memberId == request.auth.uid;
        allow update, delete: if isMember(groupId)
          && resource.data.memberId == request.auth.uid;
      }
      match /weightLogs/{logId} {
        // Crew can see weight numbers (for the dashboard trend chart and
        // celebrations like "Sara is down 2 lbs"); only the author can
        // create / modify their own log. Progress photos sit in Storage
        // under owner-only read rules — see storage.rules.
        allow read: if isMember(groupId);
        allow create: if isMember(groupId)
          && request.resource.data.memberId == request.auth.uid;
        allow update, delete: if isMember(groupId)
          && resource.data.memberId == request.auth.uid;
      }
      match /meals/{mealId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId)
          && request.resource.data.memberId == request.auth.uid;
        allow update, delete: if isMember(groupId)
          && resource.data.memberId == request.auth.uid;
      }
      match /shoppingLists/{listId} {
        allow read, write: if isMember(groupId);
      }
      match /inventory/{itemId} {
        // Shared pantry — any member can read or modify, write tracks the
        // adding/updating member via the addedBy/updatedBy fields.
        allow read, write: if isMember(groupId);
      }
      match /feed/{itemId} {
        allow read, write: if isMember(groupId);
      }
    }
  }
}
